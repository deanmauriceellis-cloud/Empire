{
  "name": "empire-reborn",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:client": "pnpm --filter @empire/client dev",
    "dev:server": "pnpm --filter @empire/server dev",
    "build": "pnpm --filter @empire/client build",
    "start": "pnpm --filter @empire/server start",
    "test": "pnpm --filter @empire/shared test && pnpm --filter @empire/server test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "tsc --noEmit"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}